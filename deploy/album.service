[Unit]
Description=Album da Copa
After=network.target

[Service]
Type=simple
User=album
Group=album
WorkingDirectory=/opt/album
Environment="SECRET_KEY=troque-por-uma-string-aleatoria-longa"
ExecStart=/opt/album/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 1
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
